{
  "name": "memran/marwa-framework",
  "description": "MarwaPHP -  A future‑proof, PSR‑compliant PHP framework core.Minimal, modular, and fast — with developer‑friendly APIs.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "http",
    "psr-3",
    "psr-7",
    "psr-11",
    "psr-15",
    "psr-16",
    "framework",
    "ecosystem",
    "PHP Framework",
    "Opensource Framework",
    "MarwaPHP Framework",
    "marwaphp",
    "Marwa Framework",
    "PHP 8",
    "marwa-router",
    "marwa-view",
    "marwa-event",
    "marwa-db",
    "marwa-module",
    "marwa-entity"
  ],
  "authors": [
    {
      "name": "Mohammad Emran",
      "email": "memran.dhk@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "memran/marwa-logger": "^1.0",
    "memran/marwa-error-handler": "^1.1",
    "memran/marwa-view": "^1.0",
    "memran/marwa-debugbar": "^1.0",
    "memran/marwa-event": "^0.2",
    "memran/marwa-router": "^1.3",
    "league/container": "^5.1",
    "symfony/dotenv": "^7.3",
    "relay/relay": "^3.0",
    "psr/event-dispatcher": "^1.0",
    "nesbot/carbon": "^3.10",
    "symfony/console": "^7.3",
    "memran/marwa-support": "^1.2",
    "memran/marwa-module": "^1.0.1",
    "memran/marwa-entity": "^1.0",
    "memran/marwa-db": "^1.2",
    "matthiasmullie/scrapbook": "^1.5",
    "league/flysystem": "^3.29",
    "league/flysystem-local": "^3.29"
  },
  "autoload": {
    "psr-4": {
      "Marwa\\Framework\\": "src/"
    },
    "files": [
      "src/Supports/Helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Marwa\\Framework\\Tests\\": "tests/"
    }
  },
  "config": {
    "platform": {
      "php": "8.2.0"
    }
  },
  "suggest": {
    "memran/marwa-db": "Optional database toolkit integration; console commands auto-register when available.",
    "memran/marwa-entity": "Optional entity builder and validation layer for domain models.",
    "memran/marwa-module": "Optional module management for modular application structure.",
    "memran/marwa-support": "Optional support helpers and utility primitives for consuming apps."
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test:coverage": "php -d xdebug.mode=coverage vendor/bin/phpunit --coverage-text",
    "analyse": "php vendor/bin/phpstan analyse --memory-limit=1G --no-progress --debug",
    "stan": "@analyse",
    "lint": "php vendor/bin/php-cs-fixer fix --dry-run --diff --verbose --sequential --allow-unsupported-php-version=yes",
    "fix": "php vendor/bin/php-cs-fixer fix --verbose --sequential --allow-unsupported-php-version=yes",
    "ci": [
      "@analyse",
      "@lint",
      "@test"
    ]
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.89",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5"
  }
}
