APP_URL=http://localhost
APP_NAME="Marwa Framework"
APP_ENV=development
APP_DEBUG=true

LOG_ENABLE=true
LOG_CHANNEL=file

DEBUGBAR_ENABLED=false

MAINTENANCE=0
MAINTENANCE_TIME=300 #in seconds
TIMEZONE=Asia/Dhaka

# Mail configuration
MAIL_DRIVER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# If using sendmail, ensure the path is quoted if it contains spaces
MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs"