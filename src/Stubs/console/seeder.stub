<?php

declare(strict_types=1);

namespace {{ namespace }};

use Marwa\Framework\Database\Seeder;

final class {{ class }} extends Seeder
{
    public function run(): void
    {
        $faker = $this->faker();

        $rows = [];
        for ($i = 0; $i < 10; $i++) {
            $rows[] = [
                'name' => $faker->name(),
                'email' => $faker->unique()->safeEmail(),
            ];
        }

        $this->insertMany('users', $rows);
    }
}
