<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Page Not Found</title>
    <style>
        * {
            box-sizing: border-box;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            color: #333;
        }
        .container {
            text-align: center;
            padding: 3rem 2rem;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
            max-width: 500px;
            margin: 1rem;
        }
        .error-code {
            font-size: 8rem;
            font-weight: 700;
            margin: 0;
            line-height: 1;
            color: #e74c3c;
            text-shadow: 2px 2px 0 #c0392b;
        }
        h1 {
            font-size: 1.5rem;
            margin: 1rem 0;
            color: #2c3e50;
        }
        p {
            font-size: 1rem;
            color: #666;
            line-height: 1.6;
            margin: 0.5rem 0;
        }
        .path {
            background: #f8f9fa;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            font-family: 'Monaco', 'Menlo', monospace;
            font-size: 0.9rem;
            color: #495057;
            display: inline-block;
            margin: 0.5rem 0;
            word-break: break-all;
        }
        .method {
            display: inline-block;
            background: #3498db;
            color: white;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-right: 0.5rem;
        }
        .debug {
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid #eee;
            font-size: 0.85rem;
            color: #888;
        }
        {% if debug %}
        .debug code {
            background: #f8f9fa;
            padding: 0.2rem 0.4rem;
            border-radius: 3px;
            font-family: 'Monaco', 'Menlo', monospace;
        }
        {% endif %}
    </style>
</head>
<body>
    <div class="container">
        <p class="error-code">404</p>
        <h1>Page Not Found</h1>
        <p><span class="method">{{ method }}</span>The page you are looking for was not found.</p>
        <p class="path">{{ path }}</p>
        {% if debug %}
        <div class="debug">
            <p>Debug mode is enabled</p>
            <p>Requested path: <code>{{ path }}</code></p>
            <p>HTTP method: <code>{{ method }}</code></p>
        </div>
        {% endif %}
    </div>
</body>
</html>
