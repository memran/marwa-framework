<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ appName }} - Server Error</title>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            color: #333;
        }
        .container {
            text-align: center;
            padding: 3rem 2rem;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
            max-width: 600px;
            margin: 1rem;
        }
        .error-code {
            font-size: 8rem;
            font-weight: 700;
            margin: 0;
            line-height: 1;
            color: #e74c3c;
            text-shadow: 2px 2px 0 #c0392b;
        }
        h1 { font-size: 1.5rem; margin: 1rem 0; color: #2c3e50; }
        p { font-size: 1rem; color: #666; line-height: 1.6; margin: 0.5rem 0; }
        .meta {
            background: #f8f9fa;
            padding: 0.75rem 1rem;
            border-radius: 6px;
            font-size: 0.85rem;
            color: #495057;
            margin: 1rem 0;
            text-align: left;
        }
        .meta code {
            background: #e9ecef;
            padding: 0.15rem 0.4rem;
            border-radius: 3px;
            font-family: 'Monaco', 'Menlo', monospace;
            font-size: 0.8rem;
        }
        .trace {
            text-align: left;
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            padding: 1rem;
            margin-top: 1.5rem;
            max-height: 300px;
            overflow: auto;
            font-size: 0.8rem;
        }
        .trace-title {
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #495057;
        }
        .trace-row {
            padding: 0.3rem 0;
            border-bottom: 1px dashed #e9ecef;
            font-family: 'Monaco', 'Menlo', monospace;
            color: #555;
        }
        .trace-row:last-child { border-bottom: none; }
        .footer {
            margin-top: 1.5rem;
            padding-top: 1rem;
            border-top: 1px solid #eee;
            font-size: 0.8rem;
            color: #999;
        }
    </style>
</head>
<body>
    <div class="container">
        <p class="error-code">500</p>
        <h1>Something went wrong</h1>

        {% if dev and exception %}
        <div class="meta">
            <strong>{{ exception.class }}</strong>: {{ exception.message }}<br>
            Thrown in <code>{{ exception.file }}</code> at line <code>{{ exception.line }}</code>
        </div>

        {% if exception.trace is not empty %}
        <div class="trace">
            <div class="trace-title">Stack Trace</div>
            {% for frame in exception.trace %}
            <div class="trace-row">#{{ loop.index0 }} <code>{{ frame.file }}:{{ frame.line }}</code> {{ frame.call }}</div>
            {% endfor %}
        </div>
        {% endif %}
        {% else %}
        <p>Please try again later.</p>
        {% endif %}

        <div class="footer">
            Reference ID: {{ requestId }}
        </div>
    </div>
</body>
</html>
