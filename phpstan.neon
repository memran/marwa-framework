parameters:
	level: 6
	parallel:
		maximumNumberOfProcesses: 1
	paths:
		- src
		- tests
	bootstrapFiles:
		- src/Authorization/Authenticatable.php
		- build-stubs/memran-marwa-db.php
	ignoreErrors:
		- identifier: trait.unused
		  path: src/Authorization/Authenticatable.php
		- identifier: nullCoalesce.offset
		  path: src/Navigation/MenuRegistry.php
		- identifier: return.type
		  path: src/Navigation/MenuRegistry.php
		- identifier: new.static
		  path: src/Mail/Mailable.php
		- identifier: return.type
		  path: src/Queue/DatabaseQueue.php
		  message: "#Method Marwa\\\\Framework\\\\Queue\\\\DatabaseQueue::(pending|failed)\\(\\) should return#"
		- identifier: class.notFound
		  path: src/Queue/DatabaseQueue.php
